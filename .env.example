# =============================================================================
# KAI Ads — Environment Variables
# Copy this file to .env and fill in real values.
# Every value here is read centrally in src/lib/env.ts — nothing in the
# codebase reads process.env directly outside of that file.
# =============================================================================

# --- App ---------------------------------------------------------------
NODE_ENV=development
APP_URL=http://localhost:3000

# --- Database (REQUIRED) ------------------------------------------------
# PostgreSQL connection string.
DATABASE_URL="postgresql://user:password@localhost:5432/kai_ads?schema=public"

# --- Better Auth (REQUIRED) ----------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth (Google Workspace login) -------------------------------
# https://console.cloud.google.com/apis/credentials
# Restrict to Workspace accounts (hd parameter / verified domains).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Microsoft OAuth (Microsoft 365 login) --------------------------------
# https://portal.azure.com -> App registrations
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID=common

# --- Magic Link email delivery ---------------------------------------------
# REQUIRED. No default — app refuses to start without an explicit choice.
# EMAIL_PROVIDER = "resend" | "smtp" | "none" (explicit opt-out for local dev)
EMAIL_PROVIDER=none
EMAIL_FROM="KAI Ads <noreply@youragency.com>"

# Resend (https://resend.com/api-keys) — used when EMAIL_PROVIDER=resend
RESEND_API_KEY=""

# SMTP — used when EMAIL_PROVIDER=smtp
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_SECURE=false

# --- File Storage (agency logos) ------------------------------------------
# REQUIRED. No default — app refuses to start without an explicit choice.
# STORAGE_PROVIDER = "s3" | "vercel-blob" | "none" (explicit opt-out for local dev)
STORAGE_PROVIDER=none

# S3 / S3-compatible (AWS S3, Cloudflare R2, MinIO) — used when STORAGE_PROVIDER=s3
STORAGE_BUCKET=""
STORAGE_REGION="auto"
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_ENDPOINT=""
STORAGE_PUBLIC_URL=""

# Vercel Blob — used when STORAGE_PROVIDER=vercel-blob
BLOB_READ_WRITE_TOKEN=""

# --- Registration policy ---------------------------------------------------
# Comma-separated list of personal email domains rejected at registration
# and join-request time. Extend without a code change.
PERSONAL_EMAIL_DOMAINS="gmail.com,yahoo.com,outlook.com,hotmail.com,live.com,icloud.com,aol.com,proton.me,protonmail.com,zoho.com,mail.com,gmx.com,yandex.com,rediffmail.com"

# --- Logging -----------------------------------------------------------
LOG_LEVEL=info

# --- Seed script (optional, dev-only) --------------------------------------
SEED_SUPER_ADMIN_EMAIL=""
SEED_SUPER_ADMIN_NAME="KAI Super Admin"

# --- KAI Intelligence Engine (Sprint 003) -----------------------------------
# Optional — without OPENAI_API_KEY, AI extraction reports itself as
# unavailable and the review screen falls back to manual entry. Model
# names are read ONLY from here — never hardcoded elsewhere in the app.
OPENAI_API_KEY=""
KAI_TEXT_MODEL=gpt-4.1-mini
KAI_VISION_MODEL=gpt-4.1-mini
