// KAI Ads — Sprint 001: Authentication & Onboarding
// Prisma schema. PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum AgencyStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum UserRole {
  KAI_SUPER_ADMIN
  AGENCY_ADMIN
  AGENCY_USER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum ApprovalTargetType {
  AGENCY
  JOIN_REQUEST
}

enum ApprovalDecision {
  APPROVE
  REJECT
  SUSPEND
  ACTIVATE
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AdvertisementStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED
}

enum AdvertisementStyle {
  VISUAL
  TYPOGRAPHY
  NEWSPAPER
}

enum AdvertisementDraftSourceType {
  PASTE_TEXT
  PDF
  DOCX
  IMAGE
  WHATSAPP_SCREENSHOT
}

enum AdvertisementDraftStatus {
  UPLOADED
  EXTRACTING
  EXTRACTED
  EXTRACTION_FAILED
  REVIEWED
  STYLE_SELECTED
  SAVED
  DISCARDED
}

enum AiOperationType {
  REQUIREMENT_EXTRACTION
  TRADE_SUMMARY
  INDUSTRY_DETECTION
  COUNTRY_DETECTION
  EMPLOYER_DETECTION
  SALARY_DETECTION
  INTERVIEW_DETECTION
  COMPOSITE_EXTRACTION
}

// ---------------------------------------------------------------------------
// Core domain models
// ---------------------------------------------------------------------------

model Agency {
  id                 String       @id @default(cuid())
  name               String
  registrationNumber String       @unique
  website            String
  officialEmail      String       @unique
  logoUrl            String
  secondaryLogoUrl   String?
  status             AgencyStatus @default(PENDING)

  domains      Domain[]
  users        User[]
  joinRequests JoinRequest[]
  approvals    Approval[]
  auditLogs    AuditLog[]

  advertisements       Advertisement[]
  advertisementDrafts  AdvertisementDraft[]
  contacts             AgencyContact[]
  aiUsageLogs          AiUsageLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("agencies")
}

model Domain {
  id        String   @id @default(cuid())
  domain    String   @unique
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([agencyId])
  @@map("domains")
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  emailVerified Boolean    @default(false)
  image         String?
  role          UserRole   @default(AGENCY_USER)
  status        UserStatus @default(PENDING)

  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  sessions      Session[]
  accounts      Account[]
  joinRequests  JoinRequest[] @relation("JoinRequestUser")
  reviewedJoins JoinRequest[] @relation("JoinRequestReviewer")
  approvalsMade Approval[]    @relation("ApprovalActor")
  auditLogs     AuditLog[]

  createdAdvertisements Advertisement[]        @relation("AdvertisementCreatedBy")
  advertisementVersions AdvertisementVersion[] @relation("AdvertisementVersionCreatedBy")
  advertisementHistory  AdvertisementHistory[] @relation("AdvertisementHistoryActor")
  advertisementDrafts   AdvertisementDraft[]   @relation("AdvertisementDraftCreatedBy")
  createdContacts       AgencyContact[]        @relation("AgencyContactCreatedBy")
  aiUsageLogs           AiUsageLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId])
  @@index([role])
  @@map("users")
}

model JoinRequest {
  id       String            @id @default(cuid())
  userId   String
  user     User              @relation("JoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  agencyId String
  agency   Agency            @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  status   JoinRequestStatus @default(PENDING)

  reviewedById String?
  reviewedBy   User?     @relation("JoinRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId, status])
  @@map("join_requests")
}

model Approval {
  id         String             @id @default(cuid())
  targetType ApprovalTargetType
  targetId   String
  decision   ApprovalDecision
  reason     String?

  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  actorId String
  actor   User   @relation("ApprovalActor", fields: [actorId], references: [id])

  createdAt DateTime @default(now())

  @@index([targetType, targetId])
  @@map("approvals")
}

model AuditLog {
  id       String  @id @default(cuid())
  action   String
  entity   String
  entityId String
  metadata Json?

  actorId String?
  actor   User?   @relation(fields: [actorId], references: [id], onDelete: SetNull)

  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([agencyId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Advertisement Intelligence Engine (Sprint 002)
//
// Architecture only in this sprint: no AI provider implementation, no
// rendering, no export. Advertisement content fields (positions, benefits,
// interview, contact, theme) are stored as Json — the Golden Rule
// ("editing one block must never affect other blocks") is enforced at the
// service layer, not by rigid columns, since the exact shape of each block
// is still expected to evolve once the AI Extraction and rendering engines
// are built in later sprints.
// ---------------------------------------------------------------------------

model Advertisement {
  id     String @id @default(cuid())
  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  // --- Advertisement Schema (Sprint 002 brief) ---
  header   String
  industry String
  country  String
  employer String? // Optional per schema
  positions Json // structured list of positions/requirements
  benefits  Json // structured list of benefits
  interview Json // interview date/location/contact details
  contact   Json // agency contact block shown on the ad
  footer    String?
  theme     Json? // free-form theme/trust-stamp flags, "store only"

  style  AdvertisementStyle @default(VISUAL)
  status AdvertisementStatus @default(DRAFT)

  currentVersion Int @default(1)

  createdById String
  createdBy   User   @relation("AdvertisementCreatedBy", fields: [createdById], references: [id])

  sourceDraftId String? @unique
  sourceDraft   AdvertisementDraft? @relation("DraftResultAdvertisement", fields: [sourceDraftId], references: [id])

  duplicatedFromId String?
  duplicatedFrom   Advertisement?  @relation("AdvertisementDuplicates", fields: [duplicatedFromId], references: [id], onDelete: SetNull)
  duplicates       Advertisement[] @relation("AdvertisementDuplicates")

  versions AdvertisementVersion[] @relation("AdvertisementVersions")
  history  AdvertisementHistory[]

  deletedAt DateTime? // soft delete ("trash"), distinct from ARCHIVED status

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId, status])
  @@index([agencyId, deletedAt])
  @@index([agencyId, industry])
  @@index([agencyId, country])
  @@index([agencyId, createdAt])
  @@map("advertisements")
}

model AdvertisementVersion {
  id              String @id @default(cuid())
  advertisementId String

  advertisement Advertisement @relation("AdvertisementVersions", fields: [advertisementId], references: [id], onDelete: Cascade)

  versionNumber Int
  snapshot      Json // full snapshot of every editable field at this version
  changeSummary String?

  createdById String
  createdBy   User   @relation("AdvertisementVersionCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@unique([advertisementId, versionNumber])
  @@index([advertisementId])
  @@map("advertisement_versions")
}

model AdvertisementHistory {
  id              String @id @default(cuid())
  advertisementId String

  advertisement Advertisement @relation(fields: [advertisementId], references: [id], onDelete: Cascade)

  action     String // created | updated | status_changed | duplicated | archived | restored | deleted | undeleted
  fromStatus AdvertisementStatus?
  toStatus   AdvertisementStatus?
  metadata   Json?

  actorId String
  actor   User   @relation("AdvertisementHistoryActor", fields: [actorId], references: [id])

  createdAt DateTime @default(now())

  @@index([advertisementId, createdAt])
  @@map("advertisement_history")
}

model AdvertisementDraft {
  id       String @id @default(cuid())
  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  sourceType    AdvertisementDraftSourceType
  rawText       String? // Paste Requirement input
  sourceFileUrl String? // Upload PDF / DOCX / Image / WhatsApp Screenshot

  // AI Extraction Review — populated by the KAI Intelligence Engine
  // (Sprint 003: a real OpenAI-backed implementation of the Sprint 002
  // provider interfaces). Nullable: extraction can fail (missing API key,
  // provider timeout, unsupported file) without losing the recruiter's
  // original rawText/sourceFileUrl — see extractionError.
  extractedData Json?
  extractionError String?

  // The recruiter's edited/approved version of extractedData — this is
  // what actually becomes the Advertisement on Save.
  reviewedData Json?

  selectedStyle AdvertisementStyle?

  status AdvertisementDraftStatus @default(UPLOADED)

  resultAdvertisement Advertisement? @relation("DraftResultAdvertisement")

  createdById String
  createdBy   User   @relation("AdvertisementDraftCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId, status])
  @@index([createdById])
  @@map("advertisement_drafts")
}

// ---------------------------------------------------------------------------
// KAI Recruitment Intelligence Engine (Sprint 003)
// ---------------------------------------------------------------------------

/**
 * Contact Directory — "Do not ask the recruiter to type contact
 * information repeatedly." A reusable set of agency contacts selectable
 * on the AI Extraction Review screen; selecting one prefills the
 * Advertisement's `contact` Json block. No FK from Advertisement back to
 * here — the contact data is copied into the ad at save time (an ad's
 * contact block must stay correct even if the source contact is later
 * edited or removed), matching "Everything editable" per block.
 */
model AgencyContact {
  id       String @id @default(cuid())
  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  name        String
  mobile      String?
  whatsapp    String?
  email       String?
  designation String?

  createdById String
  createdBy   User   @relation("AgencyContactCreatedBy", fields: [createdById], references: [id])

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([agencyId, deletedAt])
  @@map("agency_contacts")
}

/**
 * Cost Tracking — one row per AI operation. Never surfaced to normal
 * agency users (see src/server/ai README notes); exists so a future
 * credit/billing system has real usage data to calculate from on day one
 * instead of needing a backfill.
 */
model AiUsageLog {
  id String @id @default(cuid())

  operationType AiOperationType
  provider      String // e.g. "openai" — never shown to agency users
  model         String // e.g. the resolved KAI_TEXT_MODEL/KAI_VISION_MODEL value

  inputTokens  Int?
  outputTokens Int?
  estimatedCostUsd Decimal? @db.Decimal(10, 6)
  latencyMs    Int?

  success      Boolean
  errorMessage String?

  agencyId String?
  agency   Agency? @relation(fields: [agencyId], references: [id], onDelete: SetNull)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  advertisementDraftId String?

  createdAt DateTime @default(now())

  @@index([agencyId, createdAt])
  @@index([operationType])
  @@map("ai_usage_logs")
}



model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}
